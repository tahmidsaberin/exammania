# ════════════════════════════════════════════════════════
#  ExamMania — Environment Variables
#  Copy this file and rename it to  .env  (remove .example)
#  Then fill in your real values below.
# ════════════════════════════════════════════════════════


# ─── Database ────────────────────────────────────────────
# These are used by Docker to create the PostgreSQL database.
# You can keep these exact values for local development.

POSTGRES_USER=exammania
POSTGRES_PASSWORD=exammania_secret
POSTGRES_DB=exammania

# Full database connection URL (must match the three values above)
DATABASE_URL=postgresql://exammania:exammania_secret@postgres:5432/exammania


# ─── JWT Secret ──────────────────────────────────────────
# A long random string used to sign login tokens.
# Must be at least 32 characters. Use any password generator.
# Example: go to https://passwordsgenerator.net/ → set length 64 → copy result

JWT_SECRET=replace_this_with_any_long_random_string_at_least_64_chars_long!!


# ─── Google OAuth ─────────────────────────────────────────
# Get these from https://console.cloud.google.com
# APIs & Services → Credentials → Create OAuth 2.0 Client ID
# See README.md for full step-by-step instructions.

GOOGLE_CLIENT_ID=paste_your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=paste_your_google_client_secret_here


# ─── App URLs ─────────────────────────────────────────────
# For local development keep these exactly as shown.
# For production change them to your real deployed URLs.

CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=paste_your_google_client_id_here.apps.googleusercontent.com
